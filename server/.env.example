DB_URL=jdbc:postgresql://localhost:5432/incomedy
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_ALLOW_INSECURE=false

JWT_ISSUER=incomedy-server
JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# Optional VK ID auth. Routes stay disabled until both VK_ID_CLIENT_ID and VK_ID_REDIRECT_URI are configured.
# VK_ID_REDIRECT_URI must exactly match the callback URI configured in VK ID and recognized by the mobile app.
# The canonical public callback URI for the current app flow is https://incomedy.ru/auth/vk/callback.
VK_ID_CLIENT_ID=replace-with-vk-id-app-id
VK_ID_REDIRECT_URI=replace-with-mobile-vk-callback-uri
# Optional dedicated Android VK ID client for the official Android SDK path.
VK_ID_ANDROID_CLIENT_ID=
VK_ID_ANDROID_REDIRECT_URI=
VK_ID_SCOPE=vkid.personal_info
VK_ID_STATE_SECRET=
VK_ID_STATE_TTL_SECONDS=600
# Optional comma-separated Apple app ids for AASA, for example TEAMID.com.bam.incomedy.InComedy
IOS_ASSOCIATED_DOMAIN_APP_IDS=

DIAGNOSTICS_ACCESS_TOKEN=replace-with-operator-diagnostics-token
DIAGNOSTICS_RETENTION_LIMIT=1000

# Optional. If provided, distributed Redis-backed auth rate limiting is enabled.
REDIS_URL=redis://localhost:6379/0
REDIS_ALLOW_INSECURE=false
