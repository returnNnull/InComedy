DB_URL=jdbc:postgresql://localhost:5432/incomedy
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_ALLOW_INSECURE=false

JWT_ISSUER=incomedy-server
JWT_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_LOGIN_CLIENT_ID=replace-with-telegram-login-client-id
TELEGRAM_LOGIN_CLIENT_SECRET=replace-with-telegram-login-client-secret
TELEGRAM_LOGIN_REDIRECT_URI=https://incomedy.ru/auth/telegram/callback
TELEGRAM_LOGIN_STATE_SECRET=replace-with-telegram-login-state-secret
TELEGRAM_LOGIN_STATE_TTL_SECONDS=600
DIAGNOSTICS_ACCESS_TOKEN=replace-with-operator-diagnostics-token
DIAGNOSTICS_RETENTION_LIMIT=1000

# Optional. If provided, distributed Redis-backed auth rate limiting is enabled.
REDIS_URL=redis://localhost:6379/0
REDIS_ALLOW_INSECURE=false
