(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    -Server
  }
}

incomedy.ru {
    import security_headers
    header {
      Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
    reverse_proxy server:8080
}

www.incomedy.ru {
    redir https://incomedy.ru{uri}
}

api.incomedy.ru {
    import security_headers
    header {
      Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'"
    }
    reverse_proxy server:8080
}
