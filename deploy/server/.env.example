IMAGE=ghcr.io/<owner>/incomedy-server:latest

POSTGRES_DB=incomedy
POSTGRES_USER=incomedy
POSTGRES_PASSWORD=change-me
DB_SSL_MODE=disable
DB_ALLOW_INSECURE=false

JWT_ISSUER=incomedy-server
JWT_SECRET=change-me-strong-secret
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
DIAGNOSTICS_ACCESS_TOKEN=change-me-operator-token
DIAGNOSTICS_RETENTION_LIMIT=1000
PORT=8080
REDIS_URL=redis://redis:6379/0
REDIS_ALLOW_INSECURE=false
